# Clé OpenAI pour l'extraction du récurrent des comparables (P4)
OPENAI_API_KEY=sk-...

# Observabilité Sentry (optionnel — désactivé si vide)
SENTRY_DSN=

# Base de données SQLite (V1) — chemin relatif à la racine du projet
DATABASE_URL=sqlite:///./data/valo.db

# Environnement (development / production)
ENVIRONMENT=development
