# Clé OpenAI — découverte des comparables/transactions (P3b) + extraction récurrent (P4)
OPENAI_API_KEY=sk-...
# Modèle OpenAI (petit modèle par défaut pour maîtriser le coût)
OPENAI_MODEL=gpt-4o-mini

# Observabilité Sentry (optionnel — désactivé si vide)
SENTRY_DSN=

# Base de données SQLite (V1) — chemin relatif à la racine du projet
DATABASE_URL=sqlite:///./data/valo.db

# Environnement (development / production)
ENVIRONMENT=development
